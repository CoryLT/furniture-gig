# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin — the email address you'll use for the single admin account
NEXT_PUBLIC_ADMIN_EMAIL=your-admin-email@example.com

# Sightengine — image moderation API
# Sign up at sightengine.com and grab your keys from the dashboard
SIGHTENGINE_API_USER=your-api-user-number
SIGHTENGINE_API_SECRET=your-api-secret-string
